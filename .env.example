# Copy this file to .env and fill your local values.
# Do not commit real .env files.

# Required for S3 data sync scripts
YNAB_CONSOLIDATOR_S3_BUCKET=your-bucket-name

# Recommended AWS auth context (prefer profile/SSO)
AWS_PROFILE=your-aws-profile
AWS_REGION=eu-west-1

# Optional: shared path prefix inside bucket
YNAB_CONSOLIDATOR_S3_PREFIX=ynab-israel-consolidator/data/

# Optional local behavior toggles (future CLI support)
YNAB_DEFAULT_DATE_FROM=
YNAB_DEFAULT_DATE_TO=
